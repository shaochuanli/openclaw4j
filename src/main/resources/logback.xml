<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%level] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="BUFFER" class="ai.openclaw.util.LogBufferAppender"/>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${user.home}/.openclaw4j/logs/openclaw4j.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${user.home}/.openclaw4j/logs/openclaw4j.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%level] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="BUFFER"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- Quiet noisy libraries -->
    <logger name="org.eclipse.jetty" level="WARN"/>
    <logger name="org.telegram.telegrambots" level="WARN"/>
    <logger name="org.quartz" level="WARN"/>
    <logger name="okhttp3" level="WARN"/>
</configuration>

